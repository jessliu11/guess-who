# Copy this file to .env.local (Simulator/local dev) or .env (prod build).
# All EXPO_PUBLIC_* keys are embedded in the client bundle — never put secrets here.

# Supabase — anon key for client SDK. Local CLI for Simulator, prod project for device/builds.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat — public SDK keys for IAP/subscriptions (one per platform).
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_your_key_here
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_your_key_here
